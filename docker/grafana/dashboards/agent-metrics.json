{
  "__inputs": [
    {
      "name": "DS_PENTAGRON_POSTGRESQL",
      "label": "Pentagron-PostgreSQL",
      "description": "",
      "type": "datasource",
      "pluginId": "postgres",
      "pluginName": "PostgreSQL"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "postgres", "name": "PostgreSQL", "version": "1.0.0" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "table", "name": "Table", "version": "" },
    { "type": "panel", "id": "piechart", "name": "Pie chart", "version": "" },
    { "type": "panel", "id": "barchart", "name": "Bar chart", "version": "" }
  ],
  "annotations": { "list": [] },
  "description": "Pentagron Agent Metrics — flow status, tool usage, findings, and performance",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Overview",
      "type": "row"
    },
    {
      "datasource": { "type": "postgres", "uid": "${DS_PENTAGRON_POSTGRESQL}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 80 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "id": 1,
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${DS_PENTAGRON_POSTGRESQL}" },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT COUNT(*) AS value FROM flows WHERE deleted_at IS NULL",
          "refId": "A"
        }
      ],
      "title": "Total Flows",
      "type": "stat"
    },
    {
      "datasource": { "type": "postgres", "uid": "${DS_PENTAGRON_POSTGRESQL}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }, "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "id": 2,
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${DS_PENTAGRON_POSTGRESQL}" },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT COUNT(*) AS value FROM flows WHERE status = 'running' AND deleted_at IS NULL",
          "refId": "A"
        }
      ],
      "title": "Active Flows",
      "type": "stat"
    },
    {
      "datasource": { "type": "postgres", "uid": "${DS_PENTAGRON_POSTGRESQL}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }, "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "id": 3,
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${DS_PENTAGRON_POSTGRESQL}" },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT COUNT(*) AS value FROM flows WHERE status = 'completed' AND deleted_at IS NULL",
          "refId": "A"
        }
      ],
      "title": "Completed Flows",
      "type": "stat"
    },
    {
      "datasource": { "type": "postgres", "uid": "${DS_PENTAGRON_POSTGRESQL}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }] }, "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "id": 4,
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${DS_PENTAGRON_POSTGRESQL}" },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT COUNT(*) AS value FROM artifacts WHERE severity IN ('critical','high') AND created_at > NOW() - INTERVAL '24 hours'",
          "refId": "A"
        }
      ],
      "title": "Critical/High Findings (24h)",
      "type": "stat"
    },
    {
      "datasource": { "type": "postgres", "uid": "${DS_PENTAGRON_POSTGRESQL}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "orange", "value": null }] }, "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "id": 5,
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${DS_PENTAGRON_POSTGRESQL}" },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT COUNT(*) AS value FROM approval_requests WHERE status = 'pending'",
          "refId": "A"
        }
      ],
      "title": "Pending Approvals",
      "type": "stat"
    },
    {
      "datasource": { "type": "postgres", "uid": "${DS_PENTAGRON_POSTGRESQL}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "purple", "value": null }] }, "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "id": 6,
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${DS_PENTAGRON_POSTGRESQL}" },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT COUNT(*) AS value FROM actions WHERE type = 'tool_call' AND created_at > NOW() - INTERVAL '24 hours'",
          "refId": "A"
        }
      ],
      "title": "Tool Calls (24h)",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 101,
      "title": "Flow Activity",
      "type": "row"
    },
    {
      "datasource": { "type": "postgres", "uid": "${DS_PENTAGRON_POSTGRESQL}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "axisBorderShow": false, "drawStyle": "bars", "fillOpacity": 70, "lineWidth": 1 },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "id": 10,
      "options": { "legend": { "calcs": [], "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${DS_PENTAGRON_POSTGRESQL}" },
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT\n  date_trunc('hour', created_at) AS time,\n  status,\n  COUNT(*) AS value\nFROM flows\nWHERE created_at BETWEEN $__timeFrom() AND $__timeTo()\n  AND deleted_at IS NULL\nGROUP BY 1, 2\nORDER BY 1",
          "refId": "A"
        }
      ],
      "title": "Flows Created per Hour (by Status)",
      "type": "barchart"
    },
    {
      "datasource": { "type": "postgres", "uid": "${DS_PENTAGRON_POSTGRESQL}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "id": 11,
      "options": { "displayLabels": ["name", "percent"], "legend": { "displayMode": "table", "placement": "right", "values": ["value", "percent"] } },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${DS_PENTAGRON_POSTGRESQL}" },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT status AS metric, COUNT(*) AS value FROM flows WHERE deleted_at IS NULL GROUP BY status",
          "refId": "A"
        }
      ],
      "title": "Flow Status Distribution",
      "type": "piechart"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "id": 102,
      "title": "Tool Execution",
      "type": "row"
    },
    {
      "datasource": { "type": "postgres", "uid": "${DS_PENTAGRON_POSTGRESQL}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 20, "lineWidth": 2 },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "id": 20,
      "options": { "legend": { "calcs": ["sum"], "displayMode": "table", "placement": "right" } },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${DS_PENTAGRON_POSTGRESQL}" },
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT\n  date_trunc('hour', created_at) AS time,\n  tool_name AS metric,\n  COUNT(*) AS value\nFROM actions\nWHERE type = 'tool_call'\n  AND created_at BETWEEN $__timeFrom() AND $__timeTo()\nGROUP BY 1, 2\nORDER BY 1",
          "refId": "A"
        }
      ],
      "title": "Tool Calls per Hour (by Tool)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "postgres", "uid": "${DS_PENTAGRON_POSTGRESQL}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "ms" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "id": 21,
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${DS_PENTAGRON_POSTGRESQL}" },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  tool_name,\n  COUNT(*) AS call_count,\n  ROUND(AVG(duration_ms)) AS avg_ms,\n  ROUND(MAX(duration_ms)) AS max_ms,\n  ROUND(100.0 * SUM(CASE WHEN success THEN 1 ELSE 0 END) / COUNT(*), 1) AS success_pct\nFROM actions\nWHERE type = 'tool_call'\n  AND created_at BETWEEN $__timeFrom() AND $__timeTo()\nGROUP BY tool_name\nORDER BY call_count DESC",
          "refId": "A"
        }
      ],
      "title": "Tool Performance Summary",
      "type": "table",
      "options": { "sortBy": [{ "displayName": "call_count", "desc": true }] }
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "id": 103,
      "title": "Findings",
      "type": "row"
    },
    {
      "datasource": { "type": "postgres", "uid": "${DS_PENTAGRON_POSTGRESQL}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "critical" }, "properties": [{ "id": "color", "value": { "fixedColor": "#b00000", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "high" }, "properties": [{ "id": "color", "value": { "fixedColor": "#dc5000", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "medium" }, "properties": [{ "id": "color", "value": { "fixedColor": "#c8a000", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "low" }, "properties": [{ "id": "color", "value": { "fixedColor": "#3c823c", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "info" }, "properties": [{ "id": "color", "value": { "fixedColor": "#6464c8", "mode": "fixed" } }] }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "id": 30,
      "options": { "displayLabels": ["name", "value"], "legend": { "displayMode": "table", "placement": "right", "values": ["value", "percent"] } },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${DS_PENTAGRON_POSTGRESQL}" },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT severity AS metric, COUNT(*) AS value FROM artifacts WHERE created_at BETWEEN $__timeFrom() AND $__timeTo() GROUP BY severity ORDER BY value DESC",
          "refId": "A"
        }
      ],
      "title": "Findings by Severity",
      "type": "piechart"
    },
    {
      "datasource": { "type": "postgres", "uid": "${DS_PENTAGRON_POSTGRESQL}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "bars", "fillOpacity": 80, "lineWidth": 1 },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "id": 31,
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${DS_PENTAGRON_POSTGRESQL}" },
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT\n  date_trunc('hour', created_at) AS time,\n  severity AS metric,\n  COUNT(*) AS value\nFROM artifacts\nWHERE created_at BETWEEN $__timeFrom() AND $__timeTo()\nGROUP BY 1, 2\nORDER BY 1",
          "refId": "A"
        }
      ],
      "title": "Findings Over Time (by Severity)",
      "type": "barchart"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 32 },
      "id": 104,
      "title": "Recent Activity",
      "type": "row"
    },
    {
      "datasource": { "type": "postgres", "uid": "${DS_PENTAGRON_POSTGRESQL}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] } },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 33 },
      "id": 40,
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${DS_PENTAGRON_POSTGRESQL}" },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  f.name AS flow,\n  f.status,\n  f.phase,\n  f.created_at,\n  f.updated_at,\n  p.name AS project,\n  COUNT(DISTINCT a.id) AS tool_calls,\n  COUNT(DISTINCT ar.id) AS findings\nFROM flows f\nJOIN projects p ON p.id = f.project_id\nLEFT JOIN tasks t ON t.flow_id = f.id\nLEFT JOIN actions a ON a.task_id = t.id AND a.type = 'tool_call'\nLEFT JOIN artifacts ar ON ar.action_id = a.id\nWHERE f.deleted_at IS NULL\n  AND f.updated_at BETWEEN $__timeFrom() AND $__timeTo()\nGROUP BY f.id, f.name, f.status, f.phase, f.created_at, f.updated_at, p.name\nORDER BY f.updated_at DESC\nLIMIT 20",
          "refId": "A"
        }
      ],
      "title": "Recent Flows",
      "type": "table",
      "options": { "sortBy": [{ "displayName": "updated_at", "desc": true }] }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["pentagron", "agent", "security"],
  "templating": { "list": [] },
  "time": { "from": "now-24h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Pentagron — Agent Metrics",
  "uid": "pentagron-agent-metrics",
  "version": 1
}
