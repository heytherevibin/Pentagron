# Normalize line endings to LF in the repository
* text=auto eol=lf

# Force LF for shell scripts and Makefiles
Makefile text eol=lf
*.sh text eol=lf
*.bash text eol=lf

# Force LF for Go source
*.go text eol=lf

# Force LF for web
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.css text eol=lf
*.json text eol=lf

# Force LF for config/docs
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.env text eol=lf
*.toml text eol=lf
*.tmpl text eol=lf
*.sql text eol=lf
Dockerfile text eol=lf

# Binary files — no line ending conversion
*.png binary
*.jpg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.tar binary
*.gz binary
