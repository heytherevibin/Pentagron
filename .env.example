# ════════════════════════════════════════════════════════════════════════════════
# Pentagron — Environment Configuration
# Copy this file to .env and fill in your values
# ════════════════════════════════════════════════════════════════════════════════

# ── Server ────────────────────────────────────────────────────────────────────
SERVER_PORT=8080
SERVER_HOST=0.0.0.0
GIN_MODE=release                     # debug | release
LOG_LEVEL=info                       # debug | info | warn | error
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars
CORS_ORIGIN=http://localhost:3000

# ── Authentication ────────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@pentagron.local
ADMIN_PASSWORD=changeme

# ── LLM Providers ─────────────────────────────────────────────────────────────
# Default provider to use when none is specified per-agent
LLM_DEFAULT_PROVIDER=anthropic       # anthropic | openai | openrouter | deepseek | ollama
LLM_DEFAULT_MODEL=claude-sonnet-4-6

# Anthropic Claude (https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_BASE_URL=https://api.anthropic.com

# OpenAI (https://platform.openai.com)
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1

# OpenRouter (https://openrouter.ai) — 300+ models, OpenAI-compatible
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# DeepSeek (https://platform.deepseek.com) — OpenAI-compatible
DEEPSEEK_API_KEY=sk-...
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Ollama — local model execution
OLLAMA_BASE_URL=http://localhost:11434

# ── Per-agent Model Overrides ─────────────────────────────────────────────────
# Tier 1 — reasoning-heavy (orchestrator, exploit)
AGENT_MODEL_ORCHESTRATOR=claude-opus-4-6
AGENT_MODEL_PENTESTER=claude-opus-4-6
# Tier 2 — balanced (recon, coder)
AGENT_MODEL_RECON=claude-sonnet-4-6
AGENT_MODEL_CODER=claude-sonnet-4-6
# Tier 3 — fast (summarizer, reporter)
AGENT_MODEL_REPORTER=claude-haiku-4-5-20251001
AGENT_MODEL_SUMMARIZER=claude-haiku-4-5-20251001

# ── Agent Behaviour ───────────────────────────────────────────────────────────
AGENT_MAX_ITERATIONS=50
AGENT_REQUIRE_APPROVAL=true          # require human approval at phase transitions
EVOGRAPH_ENABLED=true               # persist EvoGraph to Neo4j
VECTOR_STORE_ENABLED=true           # pgvector semantic memory

# Chain summarization byte limits (configurable, defaults tuned for long engagements)
SUMMARIZER_LAST_SEC_BYTES=51200
SUMMARIZER_MAX_QA_BYTES=65536

# ── Databases ─────────────────────────────────────────────────────────────────
POSTGRES_USER=pentagron
POSTGRES_PASSWORD=pentagron
POSTGRES_DB=pentagron
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DSN=postgres://pentagron:pentagron@postgres:5432/pentagron?sslmode=disable

NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=pentagron

REDIS_URL=redis://redis:6379/0

# ── Docker ────────────────────────────────────────────────────────────────────
DOCKER_SOCKET=/var/run/docker.sock
KALI_IMAGE=pentagron-kali:latest
KALI_CONTAINER_NAME=pentagron-kali

# ── MCP Servers ───────────────────────────────────────────────────────────────
MCP_NAABU_URL=http://mcp-naabu:8000
MCP_SQLMAP_URL=http://mcp-sqlmap:8001
MCP_NUCLEI_URL=http://mcp-nuclei:8002
MCP_METASPLOIT_URL=http://mcp-metasploit:8003

# ── Search APIs (for agent web research) ─────────────────────────────────────
TAVILY_API_KEY=
PERPLEXITY_API_KEY=
SEARXNG_URL=

# ── Observability (optional) ──────────────────────────────────────────────────
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=http://langfuse-server:3000
GRAFANA_PASSWORD=admin
OTEL_EXPORTER_OTLP_ENDPOINT=
