{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "frontend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--prefix", "frontend"],
      "port": 3000
    },
    {
      "name": "backend",
      "runtimeExecutable": "go",
      "runtimeArgs": ["run", "./cmd/server"],
      "cwd": "backend",
      "port": 8080
    },
    {
      "name": "docker-dev-stack",
      "runtimeExecutable": "make",
      "runtimeArgs": ["dev"],
      "port": 8080
    }
  ]
}
